# ─── Crypto Pump Bot - Environment Variables ────────────────────────────────
# کپی این فایل به .env و مقادیر را پر کنید

# توکن ربات تلگرام (از @BotFather بگیرید) - اجباری
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# کلید API کوین‌گکو (اختیاری - برای rate limit بهتر)
COINGECKO_API_KEY=

# بازه اسکن خودکار به دقیقه (پیش‌فرض: 15)
SCAN_INTERVAL_MINUTES=15

# حداقل درصد احتمال برای هشدار (پیش‌فرض: 65)
MIN_PUMP_PROBABILITY=65.0

# حداکثر تعداد ارز برای اسکن در هر دوره (پیش‌فرض: 40)
MAX_SCAN_COINS=40
